FROM node:20-bullseye-slim

WORKDIR /app/repos/runner-web-sdk

COPY repos/runner-web-sdk/package*.json ./
RUN npm ci

COPY repos/runner-web-sdk ./
COPY web/hosting/public /app/web/hosting/public

RUN npm run build

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

CMD ["node", "./examples/demo-server.mjs"]
