{
  "name": "@computer-agents/runner-web-sdk",
  "version": "0.1.0",
  "description": "Standalone runner integration for building AI agent web apps with streaming logs.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./react/styles.css": {
      "default": "./dist/react/runner-chat.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/runner-chat-assets.mjs prepare && tsc -p tsconfig.json && node ./scripts/runner-chat-assets.mjs copy",
    "clean": "rm -rf dist",
    "history-smoke": "npm run build && node ./examples/history-api-test.mjs",
    "smoke": "npm run build && node ./examples/smoke-test.mjs",
    "demo": "npm run build && node ./examples/demo-server.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@git-diff-view/file": "^0.1.3",
    "@git-diff-view/react": "^0.1.3",
    "@monaco-editor/react": "^4.7.0",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.547.0",
    "novnc-next": "^1.0.0",
    "pdfjs-dist": "^5.4.624",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.17"
  }
}
